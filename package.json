{
  "name": "jobness",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter web dev",
    "dev:scraper": "pnpm --filter @jobness/shared build && pnpm --filter scraper dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "supabase": "^2.95.4",
    "typescript": "^5.4.5"
  }
}
