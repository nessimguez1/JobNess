NEXT_PUBLIC_SUPABASE_URL=https://bkxgkelzfcyvckjhuyzu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from Supabase dashboard>
# IMPORTANT: escape all $ in the bcrypt hash with \$ to prevent dotenv-expand interpolation
# Generate: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',10).replace(/\$/g,'\\$'))"
APP_PASSWORD_HASH=\$2b\$10\$replace-this-with-your-actual-hash
SESSION_SECRET=<32-byte hex — node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
SCRAPER_URL=<Railway public URL e.g. https://jobness-scraper.up.railway.app>
SCRAPER_SHARED_SECRET=<same value as in scraper .env>
